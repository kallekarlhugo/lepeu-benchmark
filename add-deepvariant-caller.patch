diff --git a/workflow/rules/calling-deepvariant.smk b/workflow/rules/calling-deepvariant.smk
new file mode 100644
index 0000000..e6cfd8f
--- /dev/null
+++ b/workflow/rules/calling-deepvariant.smk
@@ -0,0 +1,229 @@
+# =================================================================================================
+#     DeepVariant + GLnexus
+# =================================================================================================
+#
+# Two-stage variant calling that mirrors the per-contig structure used by GATK HaplotypeCaller:
+#
+#   1. DeepVariant runs per sample, per contig, producing one gVCF per (sample, contig).
+#      The official Google container is used via Snakemake's `container:` directive.
+#   2. GLnexus joint-genotypes across all samples for each contig, producing one VCF per contig
+#      that matches the same output contract as the HaplotypeCaller path.
+#   3. The per-contig VCFs are merged into `calling/genotyped-all.vcf.gz` (shared with all callers).
+#
+# Invocation:
+#   snakemake --use-conda --use-singularity \
+#       --singularity-args="--bind /lunarc/nobackup/projects/<project-root>" ...
+#
+# The bind path must cover the directory containing the reference, the BAMs, and the working
+# tree, so the container can read them at the same paths the host sees. On Lunarc, binding the
+# top-level project directory is usually enough.
+#
+# Downstream filtering note: only `bcftools-filter` and "none" are sensible filter choices for
+# DeepVariant output. The GATK filter options reference annotations (MQRankSum, ReadPosRankSum,
+# QD, etc.) that DeepVariant does not emit.
+# =================================================================================================
+
+
+import platform
+
+
+# Compute intervals for DeepVariant the same way as HaplotypeCaller — either a regions bed,
+# a contig-groups bed, or the bare contig name passed via `--regions`.
+def get_deepvariant_regions(wildcards):
+    if config["settings"].get("restrict-regions"):
+        return "calling/regions/{}.bed".format(wildcards.contig)
+    if config["settings"].get("contig-group-size"):
+        return "calling/contig-groups/{}.bed".format(wildcards.contig)
+    return wildcards.contig
+
+
+# Companion function that returns the file (or empty list) so we can declare it as an input
+# dependency. Without this, the bed file might not yet exist when DeepVariant tries to read it.
+def get_deepvariant_region_files(wildcards):
+    if config["settings"].get("restrict-regions"):
+        return "calling/regions/{}.bed".format(wildcards.contig)
+    if config["settings"].get("contig-group-size"):
+        return "calling/contig-groups/{}.bed".format(wildcards.contig)
+    return []
+
+
+# =================================================================================================
+#     DeepVariant: per-sample, per-contig gVCF
+# =================================================================================================
+
+
+rule call_variants:
+    input:
+        bam=get_sample_bams_wildcards,
+        bai=get_sample_bais_wildcards,
+        done=get_sample_bams_wildcards_done,
+        ref=config["data"]["reference-genome"],
+        fai=config["data"]["reference-genome"] + ".fai",
+        intervals_dummy=get_deepvariant_region_files,
+    output:
+        gvcf=(
+            "calling/called/{sample}-{contig}.g.vcf.gz"
+            if config["settings"]["keep-intermediate"]["calling"]
+            else temp("calling/called/{sample}-{contig}.g.vcf.gz")
+        ),
+        # DeepVariant always also writes a per-sample VCF in addition to the gVCF.
+        # We don't use it (GLnexus consumes the gVCF), but it has to be declared because
+        # DeepVariant will write it regardless. Marked temp so it's cleaned up.
+        vcf=temp("calling/called/{sample}-{contig}.vcf.gz"),
+        gtbi=(
+            "calling/called/{sample}-{contig}.g.vcf.gz.tbi"
+            if config["settings"]["keep-intermediate"]["calling"]
+            else temp("calling/called/{sample}-{contig}.g.vcf.gz.tbi")
+        ),
+        done=touch("calling/called/{sample}-{contig}.g.vcf.gz.done"),
+    log:
+        "logs/calling/deepvariant/{sample}-{contig}.log",
+    benchmark:
+        "benchmarks/calling/deepvariant/{sample}-{contig}.log"
+    threads: config["params"]["deepvariant"].get("num-shards", 4)
+    params:
+        model_type=config["params"]["deepvariant"].get("model-type", "WGS"),
+        regions=get_deepvariant_regions,
+        extra=config["params"]["deepvariant"].get("extra", ""),
+        intermediate_dir=config["params"]["deepvariant"].get("intermediate-dir", ""),
+    resources:
+        mem_mb=config["params"]["deepvariant"].get("mem-mb", 16000),
+    container:
+        # Pin the DeepVariant version for reproducibility of the benchmark.
+        # WGS, WES, PACBIO, and ONT_R104 model types are all bundled in this image.
+        "docker://google/deepvariant:1.6.1"
+    shell:
+        # `run_deepvariant` is the official wrapper that chains make_examples ->
+        # call_variants -> postprocess_variants. We restrict to one contig (or BED) per job
+        # for parallelism across the genome.
+        # Intermediate scratch goes to a per-job mktemp dir unless the user configured a
+        # persistent intermediate-dir.
+        'INT_DIR="{params.intermediate_dir}"; '
+        'if [ -z "$INT_DIR" ]; then INT_DIR=$(mktemp -d); fi; '
+        "run_deepvariant "
+        "--model_type={params.model_type} "
+        "--ref={input.ref} "
+        "--reads={input.bam} "
+        "--output_vcf={output.vcf} "
+        "--output_gvcf={output.gvcf} "
+        '--regions="{params.regions}" '
+        "--num_shards={threads} "
+        '--intermediate_results_dir="$INT_DIR" '
+        "{params.extra} > {log} 2>&1"
+
+
+# =================================================================================================
+#     GLnexus: joint genotyping per contig
+# =================================================================================================
+
+
+def get_glnexus_gvcfs(wildcards):
+    return expand(
+        "calling/called/{sample}-{{contig}}.g.vcf.gz",
+        sample=config["global"]["sample-names"],
+    )
+
+
+def get_glnexus_gvcf_tbis(wildcards):
+    return expand(
+        "calling/called/{sample}-{{contig}}.g.vcf.gz.tbi",
+        sample=config["global"]["sample-names"],
+    )
+
+
+def get_glnexus_gvcfs_done(wildcards):
+    return expand(
+        "calling/called/{sample}-{{contig}}.g.vcf.gz.done",
+        sample=config["global"]["sample-names"],
+    )
+
+
+rule joint_genotype:
+    input:
+        gvcfs=get_glnexus_gvcfs,
+        gvcfs_tbi=get_glnexus_gvcf_tbis,
+        dones=get_glnexus_gvcfs_done,
+    output:
+        vcf=(
+            "calling/genotyped/all.{contig}.vcf.gz"
+            if config["settings"]["keep-intermediate"]["calling"]
+            else temp("calling/genotyped/all.{contig}.vcf.gz")
+        ),
+        done=touch("calling/genotyped/all.{contig}.vcf.gz.done"),
+    log:
+        "logs/calling/glnexus/{contig}.log",
+    benchmark:
+        "benchmarks/calling/glnexus/{contig}.log"
+    threads: config["params"]["glnexus"].get("threads", 4)
+    params:
+        # DeepVariantWGS is the recommended preset for WGS Illumina data. For WES, switch to
+        # DeepVariantWES. Other presets exist for non-DeepVariant callers; see
+        # https://github.com/dnanexus-rnd/GLnexus/wiki/Configuration
+        glnexus_config=config["params"]["glnexus"].get("config", "DeepVariantWGS"),
+        # GLnexus refuses to reuse a scratch dir; name it per contig and wipe before each run.
+        scratch_dir="calling/glnexus-scratch/{contig}",
+        extra=config["params"]["glnexus"].get("extra", ""),
+    resources:
+        mem_mb=config["params"]["glnexus"].get("mem-mb", 16000),
+    conda:
+        "../envs/glnexus.yaml"
+    shell:
+        "rm -rf {params.scratch_dir}; "
+        "mkdir -p $(dirname {params.scratch_dir}); "
+        # GLnexus writes BCF to stdout; convert to bgzipped VCF for downstream rules,
+        # which expect .vcf.gz.
+        "glnexus_cli "
+        "--config {params.glnexus_config} "
+        "--dir {params.scratch_dir} "
+        "--threads {threads} "
+        "--mem-gbytes $(( {resources.mem_mb} / 1024 )) "
+        "{params.extra} "
+        "{input.gvcfs} 2> {log} "
+        "| bcftools view --threads {threads} -Oz -o {output.vcf} - 2>> {log}; "
+        # Clean up scratch after success. On failure, snakemake leaves it for inspection.
+        "rm -rf {params.scratch_dir}"
+
+
+# =================================================================================================
+#     Merge per-contig VCFs into a single genome-wide VCF
+# =================================================================================================
+# Same pattern as calling-haplotypecaller.smk -- aggregate per-contig VCFs into the single
+# `calling/genotyped-all.vcf.gz` that all downstream rules expect.
+
+
+def merge_variants_vcfs_input(wildcards):
+    fai = checkpoints.samtools_faidx.get().output[0]
+    return expand("calling/genotyped/all.{contig}.vcf.gz", contig=get_contigs(fai))
+
+
+def merge_variants_vcfs_input_done(wildcards):
+    fai = checkpoints.samtools_faidx.get().output[0]
+    return expand("calling/genotyped/all.{contig}.vcf.gz.done", contig=get_contigs(fai))
+
+
+rule merge_variants:
+    input:
+        ref=get_fai,
+        contig_groups=contigs_groups_input,
+        vcfs=merge_variants_vcfs_input,
+        done=merge_variants_vcfs_input_done,
+    output:
+        vcf="calling/genotyped-all.vcf.gz",
+        done=touch("calling/genotyped-all.vcf.gz.done"),
+    params:
+        java_opts=config["params"]["picard"].get("MergeVcfs-java-opts", ""),
+        extra=(
+            " --USE_JDK_DEFLATER true --USE_JDK_INFLATER true"
+            if platform.system() == "Darwin"
+            else ""
+        ),
+    resources:
+        mem_mb=config["params"]["picard"].get("MergeVcfs-mem-mb", 1024),
+    log:
+        "logs/calling/picard-merge-genotyped.log",
+    benchmark:
+        "benchmarks/calling/picard-merge-genotyped.log"
+    conda:
+        "../envs/picard.yaml"
+    wrapper:
+        "v5.7.0/bio/picard/mergevcfs"
