diff --git a/workflow/rules/mapping-ngm.smk b/workflow/rules/mapping-ngm.smk
new file mode 100644
index 0000000..0fb5515
--- /dev/null
+++ b/workflow/rules/mapping-ngm.smk
@@ -0,0 +1,113 @@
+# =================================================================================================
+#     Genome Indexing
+# =================================================================================================
+
+
+# NGM (NextGenMap) builds its own index files next to the reference FASTA on first invocation.
+# The exact index file names depend on NGM's k-mer/skip parameters and on the NGM version,
+# which makes tracking them as snakemake outputs brittle. We therefore use a single touch
+# sentinel as the tracked output, and rely on NGM's "build index only" behavior when invoked
+# with `-r <ref>` and no reads. Mapping rules then depend on this sentinel.
+rule ngm_index:
+    input:
+        ref=config["data"]["reference-genome"],
+        # Require the standard ref indices to be present, mirroring the other mappers.
+        refidcs=expand(
+            config["data"]["reference-genome"] + ".{ext}",
+            ext=["amb", "ann", "bwt", "pac", "sa", "fai"],
+        ),
+    output:
+        done=touch(config["data"]["reference-genome"] + ".ngm-index.done"),
+    log:
+        os.path.dirname(config["data"]["reference-genome"]) + "/logs/ngm_index.log",
+    conda:
+        "../envs/ngm.yaml"
+    shell:
+        # Running NGM with `-r` and no reads triggers index construction only.
+        # See https://github.com/Cibiv/NextGenMap/wiki/Documentation
+        "ngm -r {input.ref} > {log} 2>&1"
+
+
+# =================================================================================================
+#     Read Mapping
+# =================================================================================================
+
+# Same workaround as the other mappers: ensure the samtools tmp dir exists, since samtools
+# sort does not create it itself.
+if len(config["params"]["samtools"]["temp-dir"]) > 0:
+    os.makedirs(config["params"]["samtools"]["temp-dir"], exist_ok=True)
+
+
+# Translate the generic ["ID:..", "SM:..", "PL:.."] read group list into NGM's per-tag flags.
+# NGM uses one CLI flag per tag instead of accepting a full @RG header line.
+_NGM_RG_FLAGS = {
+    "ID": "--rg-id",
+    "SM": "--rg-sm",
+    "LB": "--rg-lb",
+    "PL": "--rg-pl",
+    "PU": "--rg-pu",
+    "CN": "--rg-cn",
+}
+
+
+def get_ngm_extra(wildcards):
+    rg_args = []
+    for tag in get_read_group_tags(wildcards):
+        key, _, val = tag.partition(":")
+        flag = _NGM_RG_FLAGS.get(key)
+        if flag is not None and val:
+            rg_args.append(flag + " '" + val + "'")
+    return " ".join(rg_args) + " " + config["params"]["ngm"]["extra"]
+
+
+# NGM uses `-q` for single-end input and `-1`/`-2` for paired-end input. After trimming,
+# get_trimmed_reads returns 1 file (SE or collapsed PE) or 2 files (PE), so we dispatch here.
+def get_ngm_reads_args(wildcards):
+    reads = get_trimmed_reads(wildcards)
+    if len(reads) == 1:
+        return "-q '" + str(reads[0]) + "'"
+    if len(reads) == 2:
+        return "-1 '" + str(reads[0]) + "' -2 '" + str(reads[1]) + "'"
+    raise Exception("Unexpected number of read files for NGM: " + str(len(reads)))
+
+
+rule map_reads:
+    input:
+        reads=get_trimmed_reads,
+        reads_done=get_trimmed_reads_done,
+        ref=config["data"]["reference-genome"],
+        refidcs=expand(
+            config["data"]["reference-genome"] + ".{ext}",
+            ext=["amb", "ann", "bwt", "pac", "sa", "fai"],
+        ),
+        index_done=config["data"]["reference-genome"] + ".ngm-index.done",
+    output:
+        (
+            "mapping/sorted/{sample}-{unit}.bam"
+            if config["settings"]["keep-intermediate"]["mapping"]
+            else temp("mapping/sorted/{sample}-{unit}.bam")
+        ),
+        touch("mapping/sorted/{sample}-{unit}.bam.done"),
+    params:
+        reads_args=get_ngm_reads_args,
+        extra=get_ngm_extra,
+        tmp_dir=config["params"]["samtools"]["temp-dir"],
+        sort_extra=config["params"]["samtools"]["sort"],
+    threads: config["params"]["ngm"]["threads"]
+    log:
+        "logs/mapping/ngm/{sample}-{unit}.log",
+    benchmark:
+        "benchmarks/mapping/ngm/{sample}-{unit}.log"
+    group:
+        "mapping"
+    conda:
+        "../envs/ngm.yaml"
+    shell:
+        # NGM emits SAM on stdout (default); pipe straight into samtools sort for the
+        # coordinate-sorted BAM that the rest of the pipeline expects. Threads are shared
+        # between NGM and samtools sort -- if you observe contention, reduce ngm:threads
+        # or split via params.
+        "ngm -r {input.ref} {params.reads_args} -t {threads} {params.extra} 2> {log} | "
+        "samtools sort -@ {threads} "
+        '-T "{params.tmp_dir}/{wildcards.sample}_{wildcards.unit}" '
+        "{params.sort_extra} -O bam -o {output[0]} - 2>> {log}"
