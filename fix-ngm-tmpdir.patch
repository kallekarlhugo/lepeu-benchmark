--- a/workflow/rules/mapping-ngm.smk	2026-05-11 15:27:22.805090300 +0200
+++ b/workflow/rules/mapping-ngm.smk	2026-05-11 15:27:02.603332400 +0200
@@ -71,6 +71,17 @@
     raise Exception("Unexpected number of read files for NGM: " + str(len(reads)))
 
 
+# Build the samtools sort `-T <prefix>` flag only when a temp-dir is configured.
+# When empty (the default), omit `-T` entirely so samtools falls back to writing tempfiles
+# next to the output. Concatenating an empty temp-dir to the sample/unit name would have
+# produced an invalid prefix at the filesystem root.
+def get_ngm_sort_tmp_arg(wildcards):
+    tmp = config["params"]["samtools"]["temp-dir"]
+    if tmp:
+        return '-T "' + tmp + "/" + wildcards.sample + "_" + wildcards.unit + '"'
+    return ""
+
+
 rule map_reads:
     input:
         reads=get_trimmed_reads,
@@ -91,7 +102,7 @@
     params:
         reads_args=get_ngm_reads_args,
         extra=get_ngm_extra,
-        tmp_dir=config["params"]["samtools"]["temp-dir"],
+        sort_tmp_arg=get_ngm_sort_tmp_arg,
         sort_extra=config["params"]["samtools"]["sort"],
     threads: config["params"]["ngm"]["threads"]
     log:
@@ -108,6 +119,5 @@
         # between NGM and samtools sort -- if you observe contention, reduce ngm:threads
         # or split via params.
         "ngm -r {input.ref} {params.reads_args} -t {threads} {params.extra} 2> {log} | "
-        "samtools sort -@ {threads} "
-        '-T "{params.tmp_dir}/{wildcards.sample}_{wildcards.unit}" '
+        "samtools sort -@ {threads} {params.sort_tmp_arg} "
         "{params.sort_extra} -O bam -o {output[0]} - 2>> {log}"
